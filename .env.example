# ── Carteira ──────────────────────────────────────────────────────────────────
# Chave privada da sua carteira MetaMask (sem 0x na frente)
# NUNCA compartilhe este arquivo com ninguém
PRIVATE_KEY=sua_chave_privada_aqui

# ── Capital ───────────────────────────────────────────────────────────────────
TRADE_AMOUNT_USD=100.0

# ── Monitoramento ─────────────────────────────────────────────────────────────
MIN_PROFIT_PERCENT=0.60
INTERVAL_SECONDS=10

# Confirmacao manual antes de executar: true = pede confirmação, false = automático
MANUAL_CONFIRM=false

# Bridge automática ao iniciar: s = faz bridge, n = pula
AUTO_BRIDGE=n

# ── RPCs ──────────────────────────────────────────────────────────────────────
BSC_RPC_URL=https://bsc-dataseed.binance.org/
ETH_RPC_URL=https://ethereum.publicnode.com

# ── Execução ──────────────────────────────────────────────────────────────────
SLIPPAGE_PCT=1.5
GAS_LIMIT=250000

# ── Coinbase Advanced Trade API ───────────────────────────────────────────────
# Gere em: coinbase.com → Configurações → API → Nova chave (permissão: trade)
COINBASE_API_KEY=organizations/SEU_ORG_ID/apiKeys/SEU_KEY_ID
COINBASE_API_SECRET=-----BEGIN EC PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END EC PRIVATE KEY-----\n

# ── WhatsApp via Twilio (opcional) ────────────────────────────────────────────
# Crie conta em twilio.com e ative o sandbox WhatsApp
TWILIO_SID=seu_account_sid
TWILIO_TOKEN=seu_auth_token
TWILIO_FROM=whatsapp:+14155238886
TWILIO_TO=whatsapp:+55119XXXXXXXX
